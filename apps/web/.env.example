# =========================================================================
# TradeSim Environment Variables Template
# =========================================================================
# Since TradeSim is built on a highly sophisticated client-side event-driven
# architecture, NO database or secret environment variables are required!
#
# Everything works beautifully out-of-the-box with zero configuration.
# If you expand the simulator to connect with external databases or live broker APIs,
# you can use these optional variables:

# Optional: Custom API Endpoint override (defaults to local relative path)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: Analytics key or logging level overrides
NEXT_PUBLIC_LOG_LEVEL=info
